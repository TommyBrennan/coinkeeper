generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  reminderDays Int?     // days without transactions before reminder (null = disabled)
  baseCurrency String   @default("USD") // preferred base currency for net worth display
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts           Account[]
  transactions       Transaction[]
  categories         Category[]
  credentials        Credential[]
  sessions           Session[]
  scheduledTransfers ScheduledTransfer[]

  receipts           Receipt[]
  spaceMemberships SpaceMember[]
  telegramLink     TelegramLink?
  telegramLinkCodes TelegramLinkCode[]
  products         Product[]
  notifications    Notification[]
  pushSubscriptions PushSubscription[]
  savedReports     SavedReport[]
  generatedReports GeneratedReport[]
}

// ─── WebAuthn Credentials ────────────────────────────────────────────

model Credential {
  id              String   @id @default(cuid())
  userId          String
  credentialId    String   @unique
  publicKey       Bytes
  counter         BigInt   @default(0)
  transports      String?  // JSON array of transport types
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Sessions ───────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─── Accounts (financial) ────────────────────────────────────────────

model Account {
  id        String   @id @default(cuid())
  userId    String
  spaceId   String?
  name      String
  type      String   // cash, bank, wallet, credit
  currency  String   @default("USD")
  balance   Float    @default(0)
  icon      String?
  color     String?
  isArchived        Boolean @default(false)
  lowBalanceThreshold Float?  // nullable — when set, triggers low_balance notification
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space? @relation(fields: [spaceId], references: [id])

  transactionsFrom       Transaction[]       @relation("FromAccount")
  transactionsTo         Transaction[]       @relation("ToAccount")
  scheduledTransfersFrom ScheduledTransfer[] @relation("ScheduledFrom")
  scheduledTransfersTo   ScheduledTransfer[] @relation("ScheduledTo")

  @@index([userId])
  @@index([spaceId])
}

// ─── Categories ──────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String?
  color     String?
  parentId  String?
  createdAt DateTime @default(now())

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent Category? @relation("SubCategories", fields: [parentId], references: [id])

  children     Category[]    @relation("SubCategories")
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
}

// ─── Transactions ────────────────────────────────────────────────────

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // expense, income, transfer
  amount      Float
  currency    String   @default("USD")
  description String?
  source      String?    // income source (e.g. employer, client name)
  date        DateTime @default(now())
  categoryId  String?
  fromAccountId String?
  toAccountId   String?
  exchangeRate  Float?
  toAmount      Float?     // amount received in destination account (for cross-currency transfers)
  receiptId   String?
  isRecurring Boolean  @default(false)
  recurringId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?         @relation(fields: [categoryId], references: [id])
  fromAccount Account?          @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount   Account?          @relation("ToAccount", fields: [toAccountId], references: [id])
  receipt     Receipt?          @relation(fields: [receiptId], references: [id])
  recurring   RecurringRule?    @relation(fields: [recurringId], references: [id])

  @@index([userId])
  @@index([userId, date])
  @@index([categoryId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([date])
}

// ─── Receipts ────────────────────────────────────────────────────────

model Receipt {
  id          String   @id @default(cuid())
  userId      String
  imagePath   String
  merchant    String?
  total       Float?
  currency    String?
  rawText     String?  // OCR raw output
  parsedData  String?  // JSON of parsed items
  processedAt DateTime?
  createdAt   DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  productPrices ProductPrice[]

  @@index([userId])
  @@index([userId, createdAt])
}

// ─── Products & Price Tracking ──────────────────────────────────────

model Product {
  id             String   @id @default(cuid())
  userId         String
  name           String   // display name (from first observation)
  normalizedName String   // lowercase, trimmed, collapsed whitespace
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prices ProductPrice[]

  @@unique([userId, normalizedName])
  @@index([userId])
}

model ProductPrice {
  id        String   @id @default(cuid())
  productId String
  receiptId String?
  merchant  String?  // store name from receipt
  unitPrice Float
  currency  String   @default("USD")
  date      DateTime // purchase date
  createdAt DateTime @default(now())

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  receipt Receipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([productId, date])
  @@index([date])
  @@index([receiptId])
}

// ─── Recurring Rules ─────────────────────────────────────────────────

model RecurringRule {
  id             String   @id @default(cuid())
  frequency      String   // daily, weekly, monthly, custom
  interval       Int      @default(1)
  nextExecution  DateTime
  lastExecution  DateTime?
  endDate        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  transactions Transaction[]

  @@index([isActive, nextExecution])
}

// ─── Scheduled Transfers ────────────────────────────────────────

model ScheduledTransfer {
  id              String   @id @default(cuid())
  userId          String
  fromAccountId   String
  toAccountId     String
  amount          Float
  currency        String   // source account currency
  rateMode        String   @default("auto") // auto, manual, final
  manualRate      Float?   // used when rateMode=manual
  finalAmount     Float?   // used when rateMode=final
  description     String?
  frequency       String   // daily, weekly, monthly
  interval        Int      @default(1) // every N days/weeks/months
  dayOfWeek       Int?     // 0=Sun..6=Sat, for weekly
  dayOfMonth      Int?     // 1-31, for monthly
  nextExecution   DateTime
  lastExecution   DateTime?
  endDate         DateTime?
  isActive        Boolean  @default(true)
  executionCount  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount Account @relation("ScheduledFrom", fields: [fromAccountId], references: [id])
  toAccount   Account @relation("ScheduledTo", fields: [toAccountId], references: [id])

  @@index([userId])
  @@index([nextExecution])
  @@index([isActive])
}

// ─── Category Corrections (AI feedback) ─────────────────────────────

model CategoryCorrection {
  id                  String   @id @default(cuid())
  userId              String
  description         String   // transaction description that was categorized
  suggestedCategoryId String?  // what AI suggested
  correctedCategoryId String   // what user actually picked
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([description])
}

// ─── Telegram Linking ────────────────────────────────────────────────

model TelegramLink {
  id        String   @id @default(cuid())
  userId    String   @unique
  chatId    String   @unique
  username  String?  // Telegram username for display
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TelegramLinkCode {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

// ─── Notifications ──────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  spaceId   String?
  type      String   // low_balance, unusual_spending, expense_reminder, transfer_confirmation, system
  title     String
  message   String
  read      Boolean  @default(false)
  priority  String   @default("medium") // high, medium, low
  metadata  String?  // JSON for extra data (accountId, amount, etc.)
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space? @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([spaceId])
}

// ─── Push Subscriptions ─────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   // public key
  auth      String   // auth secret
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Shared Spaces ───────────────────────────────────────────────────

model Space {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       SpaceMember[]
  accounts      Account[]
  notifications Notification[]
}

model SpaceMember {
  id      String @id @default(cuid())
  userId  String
  spaceId String
  role    String @default("editor") // owner, editor, viewer

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([spaceId])
}

// ─── Saved Reports ─────────────────────────────────────────────────

model SavedReport {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  format      String   @default("csv") // csv, json, pdf
  filters     String   // JSON: { type?, accountId?, categoryId?, from?, to?, periodPreset? }
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Scheduling
  scheduleEnabled   Boolean  @default(false)
  scheduleFrequency String?  // daily, weekly, monthly
  scheduleDay       Int?     // day of week (0-6) for weekly, day of month (1-31) for monthly
  scheduleTime      String?  // HH:MM display hint
  nextRunAt         DateTime?
  lastGeneratedAt   DateTime?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedReports GeneratedReport[]

  @@index([userId])
  @@index([scheduleEnabled, nextRunAt])
}

model GeneratedReport {
  id          String   @id @default(cuid())
  reportId    String
  userId      String
  format      String   // csv, json, pdf
  data        Bytes    // generated file content
  summary     String?  // JSON summary stats
  fileName    String?
  generatedAt DateTime @default(now())
  expiresAt   DateTime? // auto-cleanup after 30 days

  report SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([userId])
  @@index([expiresAt])
}

// ─── Exchange Rate History ──────────────────────────────────────────

model ExchangeRateHistory {
  id         String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Float
  date         DateTime // date the rate was recorded (truncated to day)
  createdAt    DateTime @default(now())

  @@unique([fromCurrency, toCurrency, date])
  @@index([fromCurrency, toCurrency])
  @@index([date])
}
