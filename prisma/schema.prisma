generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts           Account[]
  transactions       Transaction[]
  categories         Category[]
  credentials        Credential[]
  scheduledTransfers ScheduledTransfer[]

  spaceMemberships SpaceMember[]
}

// ─── WebAuthn Credentials ────────────────────────────────────────────

model Credential {
  id              String   @id @default(cuid())
  userId          String
  credentialId    String   @unique
  publicKey       Bytes
  counter         BigInt   @default(0)
  transports      String?  // JSON array of transport types
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Accounts (financial) ────────────────────────────────────────────

model Account {
  id        String   @id @default(cuid())
  userId    String
  spaceId   String?
  name      String
  type      String   // cash, bank, wallet, credit
  currency  String   @default("USD")
  balance   Float    @default(0)
  icon      String?
  color     String?
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space? @relation(fields: [spaceId], references: [id])

  transactionsFrom       Transaction[]       @relation("FromAccount")
  transactionsTo         Transaction[]       @relation("ToAccount")
  scheduledTransfersFrom ScheduledTransfer[] @relation("ScheduledFrom")
  scheduledTransfersTo   ScheduledTransfer[] @relation("ScheduledTo")

  @@index([userId])
  @@index([spaceId])
}

// ─── Categories ──────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String?
  color     String?
  parentId  String?
  createdAt DateTime @default(now())

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent Category? @relation("SubCategories", fields: [parentId], references: [id])

  children     Category[]    @relation("SubCategories")
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
}

// ─── Transactions ────────────────────────────────────────────────────

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // expense, income, transfer
  amount      Float
  currency    String   @default("USD")
  description String?
  source      String?    // income source (e.g. employer, client name)
  date        DateTime @default(now())
  categoryId  String?
  fromAccountId String?
  toAccountId   String?
  exchangeRate  Float?
  toAmount      Float?     // amount received in destination account (for cross-currency transfers)
  receiptId   String?
  isRecurring Boolean  @default(false)
  recurringId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?         @relation(fields: [categoryId], references: [id])
  fromAccount Account?          @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount   Account?          @relation("ToAccount", fields: [toAccountId], references: [id])
  receipt     Receipt?          @relation(fields: [receiptId], references: [id])
  recurring   RecurringRule?    @relation(fields: [recurringId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([date])
}

// ─── Receipts ────────────────────────────────────────────────────────

model Receipt {
  id          String   @id @default(cuid())
  imagePath   String
  merchant    String?
  total       Float?
  currency    String?
  rawText     String?  // OCR raw output
  parsedData  String?  // JSON of parsed items
  processedAt DateTime?
  createdAt   DateTime @default(now())

  transactions Transaction[]
}

// ─── Recurring Rules ─────────────────────────────────────────────────

model RecurringRule {
  id             String   @id @default(cuid())
  frequency      String   // daily, weekly, monthly, custom
  interval       Int      @default(1)
  nextExecution  DateTime
  lastExecution  DateTime?
  endDate        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  transactions Transaction[]
}

// ─── Scheduled Transfers ────────────────────────────────────────

model ScheduledTransfer {
  id              String   @id @default(cuid())
  userId          String
  fromAccountId   String
  toAccountId     String
  amount          Float
  currency        String   // source account currency
  rateMode        String   @default("auto") // auto, manual, final
  manualRate      Float?   // used when rateMode=manual
  finalAmount     Float?   // used when rateMode=final
  description     String?
  frequency       String   // daily, weekly, monthly
  interval        Int      @default(1) // every N days/weeks/months
  dayOfWeek       Int?     // 0=Sun..6=Sat, for weekly
  dayOfMonth      Int?     // 1-31, for monthly
  nextExecution   DateTime
  lastExecution   DateTime?
  endDate         DateTime?
  isActive        Boolean  @default(true)
  executionCount  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount Account @relation("ScheduledFrom", fields: [fromAccountId], references: [id])
  toAccount   Account @relation("ScheduledTo", fields: [toAccountId], references: [id])

  @@index([userId])
  @@index([nextExecution])
  @@index([isActive])
}

// ─── Category Corrections (AI feedback) ─────────────────────────────

model CategoryCorrection {
  id                  String   @id @default(cuid())
  userId              String
  description         String   // transaction description that was categorized
  suggestedCategoryId String?  // what AI suggested
  correctedCategoryId String   // what user actually picked
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([description])
}

// ─── Shared Spaces ───────────────────────────────────────────────────

model Space {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  SpaceMember[]
  accounts Account[]
}

model SpaceMember {
  id      String @id @default(cuid())
  userId  String
  spaceId String
  role    String @default("editor") // owner, editor, viewer

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([spaceId])
}
